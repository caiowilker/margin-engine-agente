{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FiscalInstallConfig",
  "type": "object",
  "properties": {
    "emissaoFiscal": { "type": "boolean" },
    "driver": { "enum": ["monitor", "lib"] },
    "certPath": { "type": "string" },
    "certSenha": { "type": "string" },
    "ambiente": { "enum": ["homologacao", "producao"] },
    "uf": { "type": "string", "minLength": 2, "maxLength": 2 },
    "cscId": { "type": "string" },
    "cscToken": { "type": "string" },
    "libPath": { "type": "string" },
    "libIni": { "type": "string" }
  }
}
