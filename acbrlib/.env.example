# Copiar para .env e ajustar (não commitar .env)
# ACBrLib Pro = provider OFICIAL 1.0. Manter Ambiente=2 no INI enquanto homologação.

# Windows
# ACBR_LIB_PATH=./lib/ACBrNFe64.dll
# Linux/WSL
# ACBR_LIB_PATH=./lib/libacbrnfe64.so

ACBR_LIB_INI=./data/config/acbrlib.ini
ACBR_LIB_CRYPT_KEY=

# INI do caso MFCS (padrão: margin-engine)
MFCS_INI=../../margin-engine/margin-fiscal/certification/nfce/0001-venda-simples/expected.ini

# Numeração para homologação (incrementar a cada emissão de teste)
NFE_SERIE=1
NFE_NUMERO=1
