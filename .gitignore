# Dependencias
node_modules/

# Build / executavel gerado
dist/

# Configuracao local com dados sensiveis
.env

# Dados locais da maquina (banco, logs, vault criptografado)
data/

# Frontend (tem repo proprio — copie o build como frontend-dist/)
frontend-dist/

# Fallback criptografado do cofre de credenciais
.vault
.fiscal-vault

# Backup pre-atualizacao (gerado pelo updater automatico)
data/backup-pre-update/

# Logs do npm
npm-debug.log*
npm-test-*.txt

# Saída de testes fiscais locais
test/data-test-xml/acbr/pdf/

# ACBrLib produção — binários e segredos locais
acbrlib/lib/*.dll
acbrlib/lib/*.so
acbrlib/data/cert/
acbrlib/data/cert/**
acbrlib/.env
acbrlib/data/config/acbrlib.ini
acbrlib/data/config/acbrlib.runtime.ini
homolog-acbrlib/.env
homolog-acbrlib/.last-numero
homolog-data/
RESULTADO-HOMOLOG-PRODUCAO.md

# Artefato SQLite de testes (regenerável)
test/**/*.db-shm
test/**/*.db-wal

# Pasta acidental de path Windows no WSL
C:\\ProgramData/

# Metadados Windows (WSL) — arquivos baixados da internet
*:Zone.Identifier

# Editores
.vscode/
.idea/
*.swp
*.swo
