{
  "name": "pdv-margin-engine-agente",
  "version": "1.0.0",
  "description": "Agente local PDV Margin Engine — impressora térmica, ACBr, fila offline e servidor do frontend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "install-service": "node install-service.js",
    "uninstall-service": "node install-service.js --uninstall",
    "test:fiscal": "node test/fiscal-hardening.test.js",
    "test:production": "node test/fiscal-production.test.js",
    "test:chaos": "node test/fiscal-chaos.test.js",
    "test:contract": "node test/contract.test.js",
    "test": "node test/fiscal-hardening.test.js && node test/fiscal-production.test.js && node test/fiscal-chaos.test.js",
    "manifest": "node scripts/generate-manifest.js",
    "predeploy": "node scripts/pre-deploy-check.js",
    "smoke": "node scripts/smoke-test.js",
    "smoke:integration": "node scripts/smoke-integration.js"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.4",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
