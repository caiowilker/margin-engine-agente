# ══════════════════════════════════════════════════════════════
#  PDV Margin Engine — Agente Local v3.1
#  Configuração via .env (legado) ou via ativação pelo painel
#
#  RECOMENDADO: NÃO edite este arquivo manualmente.
#  Use o endpoint de ativação: acesse http://localhost:9100
#  e siga o processo de ativação com código gerado no painel.
#
#  O arquivo data/config.json é gerado automaticamente pela ativação
#  e tem prioridade sobre as variáveis abaixo.
# ══════════════════════════════════════════════════════════════

# ── Porta do agente local ──────────────────────────────────────
PORT=9100

# ── Backend (preenchido automaticamente pela ativação) ─────────
# URL completa do servidor
BACKEND_URL=

# Token JWT do agente — gerado pelo endpoint /pdv/ativar
# NÃO preencha manualmente — use o processo de ativação
BACKEND_TOKEN=

# Timeout para considerar backend offline (ms)
BACKEND_TIMEOUT_MS=5000

# Auto-update do agente via backend (desligado por padrao — mais estavel)
AUTO_UPDATE=false

# ── Fila offline (SQLite) ──────────────────────────────────────
SYNC_INTERVAL_MS=30000
MAX_TENTATIVAS=10
DB_PATH=./data/fila.db

# ── Impressora térmica ─────────────────────────────────────────
# Tipo: auto | usb | network | windows
# auto (recomendado): detecta sozinho — Windows spooler, rede TCP e USB
PRINTER_TYPE=auto

# Nome da impressora no Windows (opcional — vazio = auto-detectar)
PRINTER_NAME=

# Se network: IP e porta da impressora na LAN
# ATENCAO: se agente usa PORT=9100, impressora de rede geralmente usa 9100 tambem.
#          O instalador corrige PRINTER_PORT para 9101 nesse caso.
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9101

# ── ACBr Monitor ───────────────────────────────────────────────
ACBR_HOST=127.0.0.1
ACBR_PORT=9200
ACBR_TIMEOUT_MS=10000
# Timeout dedicado para emissão NFC-e (autorização SEFAZ pode demorar)
ACBR_TIMEOUT_EMISSAO_MS=120000
# Timeout aguardando conclusão do job EMISSAO na fila fiscal
FISCAL_EMISSAO_TIMEOUT_MS=180000
# Intervalo da reconciliação fiscal automática (ms) — padrão 5 min
FISCAL_RECONCILIACAO_MS=300000

# ══════════════════════════════════════════════════════════════
# ── Emissão Fiscal NFC-e (OPCIONAL) ───────────────────────────
#
# Por padrão o sistema opera em modo CUPOM NÃO FISCAL.
# O cupom é válido para controle interno mas não tem validade fiscal.
#
# Para habilitar a emissão de NFC-e via SEFAZ:
#   1. Instale e configure o ACBr Monitor Pro na máquina
#   2. Configure o certificado A1 no ACBr Monitor
#   3. Defina EMISSAO_FISCAL=true abaixo
#   4. Configure a URL de contingência da sua UF (veja tabela abaixo)
#   5. Reinicie o agente
#
# EMISSAO_FISCAL=false → cupom não fiscal (padrão, sem necessidade de cert)
# EMISSAO_FISCAL=true  → tenta emitir NFC-e via ACBr; se falhar,
#                        venda é registrada sem NFC-e (não bloqueia venda)
# ══════════════════════════════════════════════════════════════
EMISSAO_FISCAL=false

# Caminho para o certificado A1 (.pfx) — necessário quando EMISSAO_FISCAL=true
# Exemplo Windows: C:\certs\empresa.pfx
# Exemplo Linux:   /opt/pdv/certs/empresa.pfx
CERT_A1_PATH=

# Senha do certificado A1
CERT_A1_PASS=

# Ambiente SEFAZ: homologacao | producao
AMBIENTE_SEFAZ=homologacao

# Série NFC-e (numeração sequencial local — evita duplicidade cStat 539)
NFE_SERIE=1

# UF do emitente (referência para validação do ACBrNFeServicos.ini)
NFE_UF=MG

# Agente como adaptador TCP — NÃO altera ACBr por padrão (boas práticas)
# true = patch automático de URL-QRCode no ACBrNFeServicos.ini (use só se souber o que faz)
ACBR_AUTO_PATCH=false
# true = grava CSC no ACBr via TCP no boot (prefira configurar na GUI do ACBr)
ACBR_AUTO_CSC=false

# CSC da NFC-e — opcional; configure preferencialmente no ACBr Monitor (WebServices/NFC-e)
# NFE_CSC_ID=000001
# NFE_CSC_TOKEN=seu-csc-de-homologacao-aqui

# Caminho do ACBrNFeServicos.ini (se não estiver na pasta padrão do ACBr)
# ACBR_NFE_SERVICOS_INI=C:\ACBrMonitorPLUS\ACBrNFeServicos.ini

# Responsável técnico (opcional — incluído no INI se CNPJ preenchido)
# NFCE_RESP_TEC_CNPJ=00000000000191
# NFCE_RESP_TEC_CONTATO=SUPORTE TECNICO
# NFCE_RESP_TEC_EMAIL=suporte@empresa.com.br
# NFCE_RESP_TEC_FONE=31999999999
# NFCE_RESP_TEC_ID_CSRT=1
# NFCE_RESP_TEC_CSRT=hash-csrt-se-houver

# ── Performance fiscal ─────────────────────────────────────────
# Preflight rápido antes de emitir (só StatusServico, cache 90s)
FISCAL_PREFLIGHT_RAPIDO=true
FISCAL_PREFLIGHT_TTL_MS=90000
# Não gera PDF DANFC-e na emissão (mais rápido — PDF sob demanda via reimprimir)
FISCAL_GERAR_PDF_ON_EMIT=false
FISCAL_POLL_MS=200
# Latência TCP ACBr (ms) — reduzir com cuidado se respostas truncarem
ACBR_BANNER_MS=80
ACBR_IDLE_MS=180

# ── Performance impressora ─────────────────────────────────────
# QR Code no cupom térmico (lento — desligado por padrão)
IMPRIMIR_QR_NFCE=false

# ── URLs SEFAZ por UF (preencha a da sua UF) ───────────────────
# Estas URLs são configuradas no ACBr Monitor (acbr.ini), não aqui.
# Estão listadas abaixo apenas como referência.
#
# MG: https://hnfe.fazenda.mg.gov.br/nfce/wsdl/NfceAutorizacao
# SP: https://homologacao.nfce.fazenda.sp.gov.br/nfceservice.asmx
# RS: https://nfce-homologacao.sefazrs.rs.gov.br/ws/NfceAutorizacao.asmx
# RJ: https://nfce.fazenda.rj.gov.br/NfceService.asmx
# PR: https://homologacao.nfce.fazenda.pr.gov.br/nfce/NfceAutorizacao
# SC: https://nfce-homologacao.sefaz.sc.gov.br/ws/NfceAutorizacao.asmx
# BA: https://hnfce.sefaz.ba.gov.br/ws/NfceAutorizacao.asmx
# ──
# URLs de contingência EPEC (também no acbr.ini, seção [NFCe]):
# AmbienteContingencia=2
# URLContingencia=<URL fornecida pela SEFAZ da sua UF>
# ══════════════════════════════════════════════════════════════
