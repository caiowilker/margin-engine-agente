# ══════════════════════════════════════════════════════════════
#  PDV Margin Engine — Agente Local v3.1
#  Configuração via .env (legado) ou via ativação pelo painel
#
#  RECOMENDADO: NÃO edite este arquivo manualmente.
#  Use o endpoint de ativação: acesse http://localhost:9100
#  e siga o processo de ativação com código gerado no painel.
#
#  O arquivo data/config.json é gerado automaticamente pela ativação
#  e tem prioridade sobre as variáveis abaixo.
# ══════════════════════════════════════════════════════════════

# ── Porta do agente local ──────────────────────────────────────
PORT=9100
AGENT_PORT=9100

# ── Backend (preenchido automaticamente pela ativação) ─────────
# URL completa do servidor
BACKEND_URL=

# Token JWT do agente — gerado pelo endpoint /pdv/ativar
# NÃO preencha manualmente — use o processo de ativação
BACKEND_TOKEN=

# Timeout para considerar backend offline (ms)
BACKEND_TIMEOUT_MS=5000

# Auto-update do agente via backend (desligado por padrao — mais estavel)
AUTO_UPDATE=false

# ── Fila offline (SQLite) ──────────────────────────────────────
SYNC_INTERVAL_MS=30000
# Intervalo de polling da config fiscal do terminal (Parte D)
CONFIG_POLL_INTERVAL_MS=45000
MAX_TENTATIVAS=10
DB_PATH=./data/fila.db

# ── Impressora térmica ─────────────────────────────────────────
# Provider oficial 1.0: acbr-posprinter (ACBrLib PosPrinter)
# Fallback: native (ESC/POS legado escpos + spooler + rede)
PRINTER_PROVIDER=acbr-posprinter
PRINTER_FALLBACK=native
PRINTER_ALLOW_PARITY=false
# PRINTER_ALLOW_PARITY=true  # somente dev/CI sem DLL PosPrinter
# PRINTER_MODEL=0
# PRINTER_PORTA=USB
# PRINTER_ENCODING=UTF8
# PRINTER_DRAWER=true
# PRINTER_LOGO_KC1=48
# PRINTER_LOGO_KC2=49
# PRINTER_BARCODE_ALTURA=50
# PRINTER_QR_ERROR_LEVEL=L
# PRINTER_SERIAL_BAUD=9600
# ACBR_POSPRINTER_INI=C:\MarginEngine\agente-local\data\posprinter.ini

# Tipo transporte ESC/POS (fallback native): auto | usb | network | windows
# auto (recomendado): detecta sozinho — Windows spooler, rede TCP e USB
PRINTER_TYPE=auto

# Nome da impressora no Windows (opcional — vazio = auto-detectar)
PRINTER_NAME=

# Se network: IP e porta da impressora na LAN (vazio = auto-detectar via spooler Windows)
# Ex.: PRINTER_HOST=192.168.0.50  PRINTER_PORT=9100
PRINTER_HOST=
PRINTER_PORT=9100

# ── Driver fiscal (Margin Platform 1.0) ─────────────────────────
# OFICIAL: ACBrLib Pro (ACBR_DRIVER=lib) — provider padrão da plataforma.
# FALLBACK: ACBr Monitor (ACBR_DRIVER=monitor) — compatibilidade / rollback.
# Ambiente SEFAZ: use PDV → Configurações → Agente Local ou GET/PUT /config/fiscal
# (grava acbrlib.ini Ambiente= + AMBIENTE_SEFAZ). Homolog=2 · Produção=1.
ACBR_DRIVER=lib
# ACBR_LIB_PATH=C:\MarginEngine\acbrlib\lib\ACBrNFe64.dll
# ACBR_LIB_INI=C:\MarginEngine\acbrlib\data\config\acbrlib.ini
# ACBR_LIB_ALLOW_PARITY=true   # APENAS dev/CI sem DLL — NÃO usar em homolog rollout

ACBR_HOST=127.0.0.1
ACBR_PORT=9200
ACBR_TIMEOUT_MS=10000
# Timeout dedicado para emissão NFC-e (autorização SEFAZ pode demorar)
ACBR_TIMEOUT_EMISSAO_MS=120000
# Timeout aguardando conclusão do job EMISSAO na fila fiscal
FISCAL_EMISSAO_TIMEOUT_MS=180000
# Intervalo da reconciliação fiscal automática (ms) — padrão 5 min
FISCAL_RECONCILIACAO_MS=300000

# ══════════════════════════════════════════════════════════════
# ── Emissão Fiscal NFC-e (OPCIONAL) ───────────────────────────
#
# Por padrão o sistema opera em modo CUPOM NÃO FISCAL.
# O cupom é válido para controle interno mas não tem validade fiscal.
#
# Para habilitar a emissão de NFC-e via SEFAZ:
#   1. Instale e configure o ACBr Monitor Pro na máquina
#   2. Configure o certificado A1 no ACBr Monitor
#   3. Defina EMISSAO_FISCAL=true abaixo
#   4. Configure a URL de contingência da sua UF (veja tabela abaixo)
#   5. Reinicie o agente
#
# EMISSAO_FISCAL=false → cupom não fiscal (padrão, sem necessidade de cert)
# EMISSAO_FISCAL=true  → tenta emitir NFC-e via ACBr; se falhar,
#                        venda é registrada sem NFC-e (não bloqueia venda)
# ══════════════════════════════════════════════════════════════
EMISSAO_FISCAL=false

# NF-e modelo 55 (nota fiscal eletrônica B2B/B2C com destinatário identificado)
# Requer EMISSAO_FISCAL=true — usa o mesmo certificado A1 e ambiente SEFAZ do NFC-e.
# ACBR_NFE_ENABLED=false desliga só NF-e; NFC-e modelo 65 continua se EMISSAO_FISCAL=true.
ACBR_NFE_ENABLED=true
# Série NF-e (contador separado do NFC-e na numeração local)
NFE_SERIE_55=1
# CFOP padrão dos itens quando não informado (5102 intra / 6102 interestadual via regra no agente)
NFE_CFOP_PADRAO=5102

# Caminho para o certificado A1 (.pfx) — necessário quando EMISSAO_FISCAL=true
# Exemplo Windows: C:\certs\empresa.pfx
# Exemplo Linux:   /opt/pdv/certs/empresa.pfx
CERT_A1_PATH=

# Senha do certificado A1
CERT_A1_PASS=

# Ambiente SEFAZ: homologacao | producao
AMBIENTE_SEFAZ=homologacao

# Série NFC-e (numeração sequencial local — evita duplicidade cStat 539)
NFE_SERIE=1

# UF do emitente (referência para validação do ACBrNFeServicos.ini)
NFE_UF=MG

# Agente NÃO altera ACBrNFeServicos.ini — URLs/CSC ficam no ACBr Monitor.
# Caminho opcional só para diagnóstico (somente leitura):
# ACBR_NFE_SERVICOS_INI=C:\ACBrMonitorPLUS\ACBrNFeServicos.ini
# ACBR_AUTO_PATCH removido — não editar INI do ACBr pelo agente.

# CSC da NFC-e — opcional; configure preferencialmente no ACBr Monitor (WebServices/NFC-e)
# NFE_CSC_ID=000001
# NFE_CSC_TOKEN=seu-csc-de-homologacao-aqui

# Caminho do ACBrNFeServicos.ini (se não estiver na pasta padrão do ACBr)
# ACBR_NFE_SERVICOS_INI=C:\ACBrMonitorPLUS\ACBrNFeServicos.ini

# Responsável técnico (opcional — incluído no INI se CNPJ preenchido)
# NFCE_RESP_TEC_CNPJ=00000000000191
# NFCE_RESP_TEC_CONTATO=SUPORTE TECNICO
# NFCE_RESP_TEC_EMAIL=suporte@empresa.com.br
# NFCE_RESP_TEC_FONE=31999999999
# NFCE_RESP_TEC_ID_CSRT=1
# NFCE_RESP_TEC_CSRT=hash-csrt-se-houver

# ── Performance fiscal ─────────────────────────────────────────
# Preflight rápido antes de emitir (só StatusServico, cache 90s)
FISCAL_PREFLIGHT_RAPIDO=true
FISCAL_PREFLIGHT_TTL_MS=90000
# PDF DANFC-e via ACBr — false = desligado (padrão; cupom na térmica ESC/POS)
FISCAL_GERAR_PDF=false
# true = gera PDF na emissão (bloqueia checkout); false = fila GERAR_PDF em background
FISCAL_GERAR_PDF_ON_EMIT=false
FISCAL_POLL_MS=200
# Emissão assíncrona (padrão): checkout não bloqueia — use FISCAL_EMITIR_SYNC=true ou ?sync=1 para modo legado
FISCAL_EMITIR_SYNC=false
# Worker fiscal (ms) — padrão 1000
FISCAL_WORKER_MS=1000
# Rate limit anti-tempestade SEFAZ
FISCAL_RATE_LIMIT_MIN=12
FISCAL_RATE_LIMIT_HORA=200
FISCAL_RATE_BACKOFF_MS=60000
# Auth agente obrigatória após ativação (recomendado produção)
AGENT_TOKEN_REQUIRED=true
# CORS — origens permitidas além de localhost (dev Vite: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173
# Legado (mesmo efeito se CORS_ORIGINS vazio): AGENTE_CORS_ORIGENS=
# Purge SQLite (dias)
FISCAL_PURGE_FILA_DIAS=30
FISCAL_PURGE_RESULTADOS_DIAS=180
FISCAL_PURGE_VENDAS_DIAS=30
# Boot: false = recovery completo; true = cancela pendentes (legado)
FISCAL_BOOT_CANCEL=false
# Purge arquivos (dias)
FISCAL_PURGE_XML_DIAS=180
FISCAL_PURGE_PDF_DIAS=180
FISCAL_PURGE_BACKUP_DIAS=90
AUDIT_RETENCAO_DIAS=90
FISCAL_MIN_DISK_MB=500
DISK_MIN_MB_XML=50
DISK_MIN_MB_PDF=50
DISK_MIN_MB_BACKUP=100
MAX_TENTATIVAS_CONSULTA=12
FISCAL_RECOVERY_MS=30000
WEBHOOK_ALERTAS_URL=
ALERTA_INCERTOS_MAX=5
RELATORIO_WEBHOOK_URL=
RELATORIO_HORARIO=23:59
# URL pública do agente (logs, instalador) — default dev: http://127.0.0.1:9100
AGENT_PUBLIC_HOST=http://127.0.0.1:9100

# Smoke tests (scripts/smoke-test.js, smoke-integration.js)
AGENTE_URL=http://127.0.0.1:9100
FISCAL_INTEGRITY_STRICT=true
ACBR_AUTO_RESTART=false
# ACBR_MONITOR_EXE=C:\ACBrMonitorPLUS\ACBrMonitor.exe
# ACBR_MONITOR_PROC=ACBrMonitor.exe
# Latência TCP ACBr (ms) — reduzir com cuidado se respostas truncarem
ACBR_BANNER_MS=80
ACBR_IDLE_MS=180

# ── Performance impressora ─────────────────────────────────────
# QR Code da NFC-e no cupom térmico (padrão: true — defina false para desligar)
IMPRIMIR_QR_NFCE=true
# Tamanho dos módulos do QR (3–8; padrão 6 — ideal para papel 80 mm)
IMPRIMIR_QR_NFCE_SIZE=6

# ── URLs SEFAZ por UF (preencha a da sua UF) ───────────────────
# Estas URLs são configuradas no ACBr Monitor (acbr.ini), não aqui.
# Estão listadas abaixo apenas como referência.
#
# MG: https://hnfe.fazenda.mg.gov.br/nfce/wsdl/NfceAutorizacao
# SP: https://homologacao.nfce.fazenda.sp.gov.br/nfceservice.asmx
# RS: https://nfce-homologacao.sefazrs.rs.gov.br/ws/NfceAutorizacao.asmx
# RJ: https://nfce.fazenda.rj.gov.br/NfceService.asmx
# PR: https://homologacao.nfce.fazenda.pr.gov.br/nfce/NfceAutorizacao
# SC: https://nfce-homologacao.sefaz.sc.gov.br/ws/NfceAutorizacao.asmx
# BA: https://hnfce.sefaz.ba.gov.br/ws/NfceAutorizacao.asmx
# ──
# URLs de contingência EPEC (também no acbr.ini, seção [NFCe]):
# AmbienteContingencia=2
# URLContingencia=<URL fornecida pela SEFAZ da sua UF>
# ══════════════════════════════════════════════════════════════
