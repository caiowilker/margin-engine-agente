# ============================================================
# PDV Margin Engine - Agente Local v6.0
# Configuracao de ambiente
#
# IMPORTANTE:
#   1. Copie este arquivo para .env
#   2. Preencha os valores conforme sua instalacao
#   3. NUNCA commite o arquivo .env no git
#
# O token JWT do backend e armazenado no Windows Credential
# Manager (nao aparece neste arquivo por seguranca).
# Para ativar o PDV, acesse http://localhost:9100 e use o
# codigo de ativacao gerado no painel do PDV Margin Engine.
# ============================================================

# ---- Porta do agente -------------------------------------------------------
# Porta em que o agente local vai escutar
PORT=9100

# ---- Banco de dados --------------------------------------------------------
# Caminho para o arquivo SQLite da fila offline
# Deixe em branco para usar o padrao (pasta data/fila.db)
DB_PATH=

# ---- Impressora termica ----------------------------------------------------
# Tipo: "usb" ou "network"
PRINTER_TYPE=usb

# Para impressora de rede (PRINTER_TYPE=network):
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9101

# Nome da impressora USB (opcional - deixe vazio para usar a primeira encontrada)
PRINTER_NAME=

# ---- ACBr Monitor (emissao fiscal NFC-e) -----------------------------------
# Habilita emissao fiscal. Se false, o agente imprime apenas cupom nao fiscal.
EMISSAO_FISCAL=false

# Endereco do ACBr Monitor (normalmente na mesma maquina)
ACBR_HOST=127.0.0.1
ACBR_PORT=9200
ACBR_TIMEOUT_MS=10000

# ---- Sincronizacao da fila offline -----------------------------------------
# Intervalo para tentar sincronizar vendas offline com o backend (ms)
SYNC_INTERVAL_MS=30000

# Maximo de tentativas antes de marcar venda como FALHA_PERMANENTE
MAX_TENTATIVAS=10

# Timeout para requisicoes ao backend (ms)
BACKEND_TIMEOUT_MS=5000

# ---- Autenticacao local ----------------------------------------------------
# Define se endpoints sensiveis exigem token local.
# true  = exige Authorization: Bearer <token> (recomendado em producao)
# false = permite acesso sem token (apenas para desenvolvimento local)
LOCAL_AUTH=true

# O token local e gerado automaticamente no primeiro boot e salvo
# no Windows Credential Manager. Para consultar o token:
#   node -e "require('./credenciais').ler().then(c=>console.log(c['local-api-token']))"

# ---- Logs ------------------------------------------------------------------
# Nivel de log: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Pasta para arquivos de log (deixe vazio para usar data/logs/)
LOG_DIR=

# ---- Identificacao do PDV (preenchido automaticamente na ativacao) ---------
# Nao edite manualmente — estes valores sao definidos pelo processo de ativacao
PDV_NOME=PDV Principal
TENANT_ID=
