# ══════════════════════════════════════════════════════════════
#  PDV Margin Engine — Agente Local v3.1
#  Configuração via .env (legado) ou via ativação pelo painel
#
#  RECOMENDADO: NÃO edite este arquivo manualmente.
#  Use o endpoint de ativação: acesse http://localhost:9100
#  e siga o processo de ativação com código gerado no painel.
#
#  O arquivo data/config.json é gerado automaticamente pela ativação
#  e tem prioridade sobre as variáveis abaixo.
# ══════════════════════════════════════════════════════════════

# ── Porta do agente local ──────────────────────────────────────
PORT=9100

# ── Backend (preenchido automaticamente pela ativação) ─────────
# URL completa do servidor
BACKEND_URL=

# Token JWT do agente — gerado pelo endpoint /pdv/ativar
# NÃO preencha manualmente — use o processo de ativação
BACKEND_TOKEN=

# Timeout para considerar backend offline (ms)
BACKEND_TIMEOUT_MS=5000

# ── Fila offline (SQLite) ──────────────────────────────────────
SYNC_INTERVAL_MS=30000
MAX_TENTATIVAS=10
DB_PATH=./data/fila.db

# ── Impressora térmica ─────────────────────────────────────────
# Tipo: usb | network
PRINTER_TYPE=usb

# Se usb: nome exato da impressora (vazio = auto-detectar)
PRINTER_NAME=

# Se network: IP e porta da impressora na rede
# ATENÇÃO: NÃO use a porta 9100 se o agente também usa 9100 (PORT acima).
#          Impressoras de rede geralmente usam 9100, mas o agente também.
#          Nesse caso: ou mude PORT para 9090, ou mude PRINTER_PORT para 9101.
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9101

# ── ACBr Monitor ───────────────────────────────────────────────
ACBR_HOST=127.0.0.1
ACBR_PORT=9200
ACBR_TIMEOUT_MS=10000

# ══════════════════════════════════════════════════════════════
# ── Emissão Fiscal NFC-e (OPCIONAL) ───────────────────────────
#
# Por padrão o sistema opera em modo CUPOM NÃO FISCAL.
# O cupom é válido para controle interno mas não tem validade fiscal.
#
# Para habilitar a emissão de NFC-e via SEFAZ:
#   1. Instale e configure o ACBr Monitor Pro na máquina
#   2. Configure o certificado A1 no ACBr Monitor
#   3. Defina EMISSAO_FISCAL=true abaixo
#   4. Configure a URL de contingência da sua UF (veja tabela abaixo)
#   5. Reinicie o agente
#
# EMISSAO_FISCAL=false → cupom não fiscal (padrão, sem necessidade de cert)
# EMISSAO_FISCAL=true  → tenta emitir NFC-e via ACBr; se falhar,
#                        venda é registrada sem NFC-e (não bloqueia venda)
# ══════════════════════════════════════════════════════════════
EMISSAO_FISCAL=false

# Caminho para o certificado A1 (.pfx) — necessário quando EMISSAO_FISCAL=true
# Exemplo Windows: C:\certs\empresa.pfx
# Exemplo Linux:   /opt/pdv/certs/empresa.pfx
CERT_A1_PATH=

# Senha do certificado A1
CERT_A1_PASS=

# Ambiente SEFAZ: homologacao | producao
# Use homologacao para testes — NFC-e emitida não tem validade fiscal
# Use producao apenas quando o certificado for de produção
AMBIENTE_SEFAZ=homologacao

# ── URLs SEFAZ por UF (preencha a da sua UF) ───────────────────
# Estas URLs são configuradas no ACBr Monitor (acbr.ini), não aqui.
# Estão listadas abaixo apenas como referência.
#
# MG: https://hnfe.fazenda.mg.gov.br/nfce/wsdl/NfceAutorizacao
# SP: https://homologacao.nfce.fazenda.sp.gov.br/nfceservice.asmx
# RS: https://nfce-homologacao.sefazrs.rs.gov.br/ws/NfceAutorizacao.asmx
# RJ: https://nfce.fazenda.rj.gov.br/NfceService.asmx
# PR: https://homologacao.nfce.fazenda.pr.gov.br/nfce/NfceAutorizacao
# SC: https://nfce-homologacao.sefaz.sc.gov.br/ws/NfceAutorizacao.asmx
# BA: https://hnfce.sefaz.ba.gov.br/ws/NfceAutorizacao.asmx
# ──
# URLs de contingência EPEC (também no acbr.ini, seção [NFCe]):
# AmbienteContingencia=2
# URLContingencia=<URL fornecida pela SEFAZ da sua UF>
# ══════════════════════════════════════════════════════════════
